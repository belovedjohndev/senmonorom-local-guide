---
const trustPoints = [
  {
    title: "Confirmed with owners",
    description: "Business owners provide or confirm key details before publishing."
  },
  {
    title: "Checked locally when possible",
    description: "Listings are reviewed locally instead of copied from random directories."
  },
  {
    title: "Built for direct contact",
    description: "Visitors can use maps, phone, WhatsApp, Facebook, or website links when available."
  }
];
---

<section>
  <div class="container">
    <div class="section-heading section-heading-centered">
      <h2>How this guide builds trust</h2>
      <p>Listings are published only when the details can be checked or confirmed.</p>
    </div>

    <div class="trust-grid">
      {
        trustPoints.map((point) => (
          <article class="trust-card">
            <h3>{point.title}</h3>
            <p>{point.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
