---
const statuses = [
  {
    label: "Verified",
    description: "Owner-confirmed or locally checked.",
    tone: "verified"
  },
  {
    label: "Being verified",
    description: "Known business, but details are not ready to publish yet.",
    tone: "pending"
  },
  {
    label: "Needs update",
    description: "Previously listed but may need refreshed details.",
    tone: "warning"
  }
];
---

<section class="section-muted">
  <div class="container narrow-container">
    <div class="section-heading section-heading-centered">
      <h2>How listing status works</h2>
    </div>

    <div class="status-grid">
      {
        statuses.map((status) => (
          <article class={`status-card status-card-${status.tone}`}>
            <h3>{status.label}</h3>
            <p>{status.description}</p>
          </article>
        ))
      }
    </div>

    <p class="trust-warning">
      <strong>Trust warning:</strong> Unverified contact details should not be presented as
      confirmed.
    </p>
  </div>
</section>
