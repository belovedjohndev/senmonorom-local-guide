---
const statuses = [
  {
    label: "Verified",
    description: "Owner-confirmed or locally checked.",
    tone: "verified",
    icon:
      '<svg viewBox="0 0 24 24" focusable="false"><path d="M20 6 9 17l-5-5"/></svg>'
  },
  {
    label: "Being verified",
    description: "Known business, but details are not ready to publish yet.",
    tone: "pending",
    icon:
      '<svg viewBox="0 0 24 24" focusable="false"><circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/></svg>'
  },
  {
    label: "Needs update",
    description: "Previously listed but may need refreshed details.",
    tone: "warning",
    icon:
      '<svg viewBox="0 0 24 24" focusable="false"><path d="M12 8v4.5M12 16.5h.01"/><path d="M10.3 4.2 2.8 17.1a2 2 0 0 0 1.7 3h15a2 2 0 0 0 1.7-3L13.7 4.2a2 2 0 0 0-3.4 0Z"/></svg>'
  }
];
---

<section class="section-muted">
  <div class="container narrow-container">
    <div class="section-heading section-heading-centered">
      <h2>How listing status works</h2>
    </div>

    <div class="status-grid">
      {
        statuses.map((status) => (
          <article class={`status-card status-card-${status.tone}`}>
            <span class="status-icon" aria-hidden="true" set:html={status.icon}></span>
            <h3>{status.label}</h3>
            <p>{status.description}</p>
          </article>
        ))
      }
    </div>

    <p class="trust-warning">
      <strong>Trust warning:</strong> Unverified contact details should not be presented as
      confirmed.
    </p>
  </div>
</section>
