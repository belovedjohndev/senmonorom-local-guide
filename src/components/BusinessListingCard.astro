---
import {
  categoryLabels,
  getTelHref,
  getWhatsAppHref,
  hasExternalUrl,
  type BusinessListing
} from "../data/businessListings";

type Props = {
  listing: BusinessListing;
  headingTag?: "h2" | "h3";
};

const { listing, headingTag = "h3" } = Astro.props as Props;
const HeadingTag = headingTag;
const formatter = new Intl.DateTimeFormat("en-US", {
  dateStyle: "long",
  timeZone: "UTC"
});

const listingInitials = listing.name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((word) => word[0]?.toUpperCase() ?? "")
  .join("");

const badgeText =
  listing.verificationStatus === "verified" ? "Owner-confirmed" : "Needs verification";
const formattedVerifiedAt =
  listing.verificationStatus === "verified" && listing.verifiedAt
    ? formatter.format(new Date(`${listing.verifiedAt}T00:00:00Z`))
    : null;
const hasGoogleMapsUrl = hasExternalUrl(listing.googleMapsUrl);
const hasWebsiteUrl = hasExternalUrl(listing.websiteUrl);
const hasFacebookUrl = hasExternalUrl(listing.facebookUrl);
const hasActions = hasGoogleMapsUrl || listing.phone || hasWebsiteUrl || hasFacebookUrl;

function getWebpUrl(url?: string): string | null {
  if (!url || !url.startsWith("/") || !/\.(jpe?g|png)$/i.test(url)) {
    return null;
  }

  return url.replace(/\.(jpe?g|png)$/i, ".webp");
}

const listingPhotoWebpUrl = getWebpUrl(listing.photoUrl);
const listingLogoWebpUrl = getWebpUrl(listing.logoUrl);

const icons = {
  calendar:
    '<svg viewBox="0 0 24 24" focusable="false"><path d="M8 2v4M16 2v4M3.5 9.5h17M5.5 4.5h13a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-13a2 2 0 0 1-2-2v-12a2 2 0 0 1 2-2Z"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" focusable="false"><circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/></svg>',
  facebook:
    '<svg viewBox="0 0 24 24" focusable="false"><path d="M14 8.5h2V5.2c-.35-.05-1.55-.15-2.95-.15-2.9 0-4.9 1.8-4.9 5.05v2.85H5v3.7h3.15V22h3.85v-5.35h3.15l.5-3.7H12v-2.5c0-1.05.3-1.95 2-1.95Z"/></svg>',
  globe:
    '<svg viewBox="0 0 24 24" focusable="false"><circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17M12 3.5c2.25 2.25 3.35 5.1 3.35 8.5S14.25 18.25 12 20.5M12 3.5C9.75 5.75 8.65 8.6 8.65 12S9.75 18.25 12 20.5"/></svg>',
  mapPin:
    '<svg viewBox="0 0 24 24" focusable="false"><path d="M20 10.5c0 5.5-8 10-8 10s-8-4.5-8-10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10.5" r="2.5"/></svg>',
  phone:
    '<svg viewBox="0 0 24 24" focusable="false"><path d="M7.5 4.5 10 7 8.5 9.5c1.3 2.65 3.35 4.7 6 6L17 14l2.5 2.5-1 3c-.25.75-1 1.2-1.8 1.05C9.6 19.3 4.7 14.4 3.45 7.3 3.3 6.5 3.75 5.75 4.5 5.5l3-1Z"/></svg>',
  shield:
    '<svg viewBox="0 0 24 24" focusable="false"><path d="M12 3.5 19 6v5.2c0 4.35-2.85 7.75-7 9.3-4.15-1.55-7-4.95-7-9.3V6l7-2.5Z"/><path d="m8.7 12.1 2.1 2.1 4.7-5"/></svg>',
  whatsapp:
    '<svg viewBox="0 0 24 24" focusable="false"><path d="M4 20.5 5.2 17A8.5 8.5 0 1 1 8 19.4L4 20.5Z"/><path d="M9.1 8.1c.2-.45.4-.45.7-.45h.5c.15 0 .35 0 .55.4.2.5.7 1.75.75 1.9.1.15.1.3 0 .5-.15.25-.25.35-.45.55-.2.2-.35.35-.15.7.2.35.8 1.35 1.7 2.1 1.15 1.05 2.15 1.35 2.5 1.5.35.1.55.1.75-.15.25-.3.85-1 1.05-1.35.25-.35.45-.3.75-.2.3.1 1.85.85 2.15 1.05.3.15.5.25.6.4.05.15.05.9-.25 1.75-.35.85-1.75 1.6-2.45 1.65-.65.05-1.45.25-4.7-1.05-3.95-1.55-6.45-5.55-6.65-5.8-.2-.25-1.6-2.1-1.6-4.05 0-1.9.95-2.85 1.3-3.25Z"/></svg>'
};
---

<article class="listing-card">
  <div class="listing-media">
    {listing.photoUrl ? (
      <>
        <picture class="listing-picture">
          {listingPhotoWebpUrl && <source srcset={listingPhotoWebpUrl} type="image/webp" />}
          <img
            class="listing-photo"
            src={listing.photoUrl}
            alt={listing.photoAlt ?? `${listing.name} photo`}
            loading="lazy"
          />
        </picture>
        {listing.logoUrl && (
          <div class="listing-logo-badge">
            <picture class="listing-logo-picture">
              {listingLogoWebpUrl && <source srcset={listingLogoWebpUrl} type="image/webp" />}
              <img class="listing-logo" src={listing.logoUrl} alt={`${listing.name} logo`} loading="lazy" />
            </picture>
          </div>
        )}
      </>
    ) : (
      <div class="listing-media-fallback" aria-label={`Placeholder for ${listing.name} photo`}>
        {listing.logoUrl ? (
          <picture class="listing-logo-picture">
            {listingLogoWebpUrl && <source srcset={listingLogoWebpUrl} type="image/webp" />}
            <img class="listing-logo" src={listing.logoUrl} alt={`${listing.name} logo`} loading="lazy" />
          </picture>
        ) : (
          <span class="listing-initials" aria-hidden="true">{listingInitials}</span>
        )}
        <p class="listing-media-note">Owner-approved photo can be added here.</p>
      </div>
    )}
  </div>

  <div class="listing-header">
    <div>
      <HeadingTag>{listing.name}</HeadingTag>
      <div class="tag-row" aria-label="Business categories">
        {listing.category.map((category) => <span class="tag">{categoryLabels[category]}</span>)}
      </div>
    </div>
    <div class="badge-row">
      <span class={`badge ${listing.verificationStatus === "verified" ? "badge-verified" : "badge-pending"}`}>
        <span class="badge-icon" aria-hidden="true" set:html={icons.shield}></span>
        {badgeText}
      </span>
    </div>
  </div>

  <p>{listing.description}</p>

  <ul class="meta-list">
    {listing.openingHours && (
      <li>
        <span class="meta-icon" aria-hidden="true" set:html={icons.clock}></span>
        <span class="meta-copy">
          <span class="meta-label">Hours</span>
          <span class="meta-value">{listing.openingHours}</span>
        </span>
      </li>
    )}
    {listing.phone && (
      <li>
        <span class="meta-icon" aria-hidden="true" set:html={icons.phone}></span>
        <span class="meta-copy">
          <span class="meta-label">Phone</span>
          <a class="meta-value" href={getTelHref(listing.phone)}>{listing.phone}</a>
        </span>
      </li>
    )}
    <li>
      <span class="meta-icon" aria-hidden="true" set:html={icons.mapPin}></span>
      <span class="meta-copy">
        <span class="meta-label">Location</span>
        <span class="meta-value">{listing.locationLabel}</span>
      </span>
    </li>
    {formattedVerifiedAt && (
      <li>
        <span class="meta-icon" aria-hidden="true" set:html={icons.calendar}></span>
        <span class="meta-copy">
          <span class="meta-label">Last verified</span>
          <span class="meta-value">{formattedVerifiedAt}</span>
        </span>
      </li>
    )}
  </ul>

  {hasActions && (
    <div class="button-row">
      {hasGoogleMapsUrl && (
        <a class="button action-button" href={listing.googleMapsUrl} target="_blank" rel="noreferrer">
          <span class="action-icon" aria-hidden="true" set:html={icons.mapPin}></span>
          Maps
        </a>
      )}
      {listing.phone && (
        <a class="button-secondary action-button" href={getTelHref(listing.phone)}>
          <span class="action-icon" aria-hidden="true" set:html={icons.phone}></span>
          Call
        </a>
      )}
      {listing.phone && (
        <a class="button-secondary action-button" href={getWhatsAppHref(listing.phone)} target="_blank" rel="noreferrer">
          <span class="action-icon" aria-hidden="true" set:html={icons.whatsapp}></span>
          WhatsApp
        </a>
      )}
      {hasWebsiteUrl && (
        <a class="button-secondary action-button" href={listing.websiteUrl} target="_blank" rel="noreferrer">
          <span class="action-icon" aria-hidden="true" set:html={icons.globe}></span>
          Website
        </a>
      )}
      {hasFacebookUrl && (
        <a class="button-secondary action-button" href={listing.facebookUrl} target="_blank" rel="noreferrer">
          <span class="action-icon" aria-hidden="true" set:html={icons.facebook}></span>
          Facebook
        </a>
      )}
    </div>
  )}
</article>
