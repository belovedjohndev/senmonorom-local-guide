---
import BusinessListingCard from "../components/BusinessListingCard.astro";
import CategoryPageNav from "../components/CategoryPageNav.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getListingsByCategory } from "../data/businessListings";

const listings = getListingsByCategory("tour");
const listingCountLabel = listings.length === 1 ? "1 verified listing" : `${listings.length} verified listings`;
---

<BaseLayout
  title="Tours in Sen Monorom | Sen Monorom Local Guide"
  description="Tour listings in Sen Monorom are being verified before publication."
>
  <section>
    <div class="container">
      <div class="content-panel page-header">
        <h1>Tours</h1>
        <p class="page-count">{listingCountLabel}</p>
        <p>
          Tour listings will be added only after owner confirmation or field verification to keep the
          guide trustworthy.
        </p>
      </div>

      <CategoryPageNav activeCategory="tour" />

      {
        listings.length > 0 ? (
          <div class="grid listing-grid">
            {listings.map((listing) => <BusinessListingCard listing={listing} headingTag="h2" />)}
          </div>
        ) : (
          <div class="empty-state">
            <h2>Listings are being verified</h2>
            <p>Listings are being verified. Local owners can submit details for a free listing.</p>
            <p>
              Know a local business that should be listed? Send us the business name or Facebook page and
              we will verify it.
            </p>
            <div class="button-row">
              <a class="button" href="/submit-business">Submit a business</a>
            </div>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
