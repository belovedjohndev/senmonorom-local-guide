---
import BusinessListingCard from "../components/BusinessListingCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  categoryLabels,
  getListingsByCategory,
  getVerifiedListings,
  type BusinessCategory,
  type BusinessListing
} from "../data/businessListings";

const verifiedListings = getVerifiedListings();
const verifiedListingCountLabel =
  verifiedListings.length === 1
    ? "1 owner-confirmed place"
    : `${verifiedListings.length} owner-confirmed places`;

const directoryFilters: {
  id: "all" | "eat" | "tours" | "stay" | "services";
  label: string;
  categories: BusinessCategory[];
}[] = [
  { id: "all", label: "All", categories: [] },
  { id: "eat", label: "Eat", categories: ["restaurant", "cafe"] },
  { id: "tours", label: "Tours", categories: ["tour"] },
  { id: "stay", label: "Stay", categories: ["guesthouse"] },
  { id: "services", label: "Services", categories: ["motorbike-rental", "local-product"] }
];

const directoryFiltersWithCounts = directoryFilters.map((filter) => {
  const count =
    filter.id === "all"
      ? verifiedListings.length
      : verifiedListings.filter((listing) =>
          listing.category.some((category) => filter.categories.includes(category))
        ).length;

  return {
    ...filter,
    count,
    isEmpty: filter.id !== "all" && count === 0
  };
});

function getDirectoryGroups(listing: BusinessListing): string[] {
  return directoryFiltersWithCounts
    .filter((filter) => filter.id !== "all")
    .filter((filter) => listing.category.some((category) => filter.categories.includes(category)))
    .map((filter) => filter.id);
}

function getDirectorySearchText(listing: BusinessListing): string {
  return [
    listing.name,
    listing.description,
    listing.locationLabel,
    ...listing.category,
    ...listing.category.map((category) => categoryLabels[category]),
    ...listing.tags
  ]
    .join(" ")
    .toLowerCase();
}

const categoryCards = [
  {
    title: "Cafes",
    href: "/cafes",
    category: "cafe",
    description: "See the first verified listings for cafes and bakery stops in Sen Monorom.",
    ctaLabel: "Browse cafes"
  },
  {
    title: "Restaurants",
    href: "/restaurants",
    category: "restaurant",
    description: "Browse owner-confirmed places for meals, coffee, and practical tourist stops.",
    ctaLabel: "Browse restaurants"
  },
  {
    title: "Guesthouses",
    href: "/guesthouses",
    category: "guesthouse",
    description: "Guesthouse listings are being verified and will be added carefully over time.",
    ctaLabel: "Suggest a guesthouse"
  },
  {
    title: "Tours",
    href: "/tours",
    category: "tour",
    description: "Browse owner-confirmed local tour services added through direct verification.",
    ctaLabel: "Browse tours"
  },
  {
    title: "Motorbike Rentals",
    href: "/motorbike-rentals",
    category: "motorbike-rental",
    description: "Motorbike rental details are being verified to keep information practical and reliable.",
    ctaLabel: "Suggest a rental"
  }
].map((card) => {
  const count = "category" in card ? getListingsByCategory(card.category as BusinessCategory).length : null;
  const statusLabel =
    count === null ? "" : count === 0 ? "Coming soon" : `${count} verified`;

  return {
    ...card,
    count,
    statusLabel
  };
});
---

<BaseLayout
  title="Sen Monorom Local Guide | Verified Local Businesses in Mondulkiri"
  description="A simple local guide being verified with owner-confirmed listings in Sen Monorom, Mondulkiri."
>
  <section class="hero">
    <div class="container">
      <div class="hero-stage">
        <div
          class="hero-media"
          role="img"
          aria-label="Chrey Thom Waterfall in Mondulkiri used as the homepage background"
        >
          <picture class="hero-picture" aria-hidden="true">
            <source srcset="/images/hero-mondulkiri-waterfall.webp" type="image/webp" />
            <img src="/images/hero-mondulkiri-waterfall.jpg" alt="" />
          </picture>
        </div>
        <div class="hero-content">
          <div class="eyebrow hero-eyebrow">Owner-confirmed listings now being added</div>
          <h1 class="hero-title">Sen Monorom Local Guide</h1>
          <p class="lead hero-lead">
            Follow owner-confirmed places to eat, plan tours, and discover local services in Sen
            Monorom, Mondulkiri.
          </p>
          <p class="hero-note">
            Built from owner-confirmed details and local field verification.
          </p>
          <div class="button-row hero-actions">
            <a class="button" href="#verified-listings">Browse verified listings</a>
          </div>
        </div>
      </div>
      <p class="hero-credit hero-credit-below">
        Hero image adapted from a public-domain photo of Chrey Thom Waterfall in Mondulkiri.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-heading">
        <h2>Browse the guide</h2>
        <p>The directory is still being expanded, so each section reflects what has already been verified.</p>
      </div>
      <div class="grid category-grid">
        {
          categoryCards.map((card) => (
            <a class={`category-card ${card.count === 0 ? "category-card-empty" : ""}`} href={card.href}>
              <div>
                <div class="category-card-header">
                  <h3>{card.title}</h3>
                  <span class={`category-status ${card.count === 0 ? "category-status-empty" : ""}`}>
                    {card.statusLabel}
                  </span>
                </div>
                <p>{card.description}</p>
              </div>
              <span class="card-link">{card.ctaLabel}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="verified-listings">
    <div class="container" data-directory>
      <div class="section-heading">
        <h2>Verified listings</h2>
        <p>
          These are the first verified listings currently published in the guide with owner-confirmed
          details.
        </p>
      </div>

      <div class="directory-controls" aria-label="Filter verified listings">
        <div class="directory-search">
          <label for="directory-search-input">Search verified places</label>
          <input
            id="directory-search-input"
            type="search"
            placeholder="Search by name, food, tour, place..."
            autocomplete="off"
            data-directory-search
          />
        </div>

        <div class="directory-filter-row" role="group" aria-label="Listing category filters">
          {
            directoryFiltersWithCounts.map((filter) => (
              <button
                class={`filter-pill ${filter.id === "all" ? "is-active" : ""} ${
                  filter.isEmpty ? "filter-pill-empty" : ""
                }`}
                type="button"
                data-directory-filter={filter.id}
                aria-pressed={filter.id === "all" ? "true" : "false"}
              >
                <span>{filter.label}</span>
                <span class="filter-count" aria-label={`${filter.count} verified listings`}>
                  {filter.count}
                </span>
              </button>
            ))
          }
        </div>

        <p class="result-count" aria-live="polite" data-directory-count>{verifiedListingCountLabel}</p>
      </div>

      <div class="grid listing-grid directory-listing-grid">
        {
          verifiedListings.map((listing) => (
            <div
              class="directory-listing-item"
              data-directory-item
              data-category-groups={getDirectoryGroups(listing).join(" ")}
              data-search-text={getDirectorySearchText(listing)}
            >
              <BusinessListingCard listing={listing} headingTag="h3" />
            </div>
          ))
        }
      </div>

      <div class="empty-state directory-empty-state" data-directory-empty hidden>
        <h2>No verified places found.</h2>
        <p>Know a good Sen Monorom business? Suggest it for verification.</p>
        <div class="button-row">
          <a class="button" href="/submit-business">Suggest one</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="cta-panel">
        <h2>Free listing for local businesses</h2>
        <p>Own a business in Sen Monorom? Submit your details for a free listing.</p>
        <a class="button" href="/submit-business">Submit your business</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-directory]");

      if (!root) {
        return;
      }

      const filterButtons = Array.from(root.querySelectorAll("[data-directory-filter]"));
      const searchInput = root.querySelector("[data-directory-search]");
      const listingItems = Array.from(root.querySelectorAll("[data-directory-item]"));
      const resultCount = root.querySelector("[data-directory-count]");
      const emptyState = root.querySelector("[data-directory-empty]");
      const validCategories = new Set(["all", "eat", "tours", "stay", "services"]);

      if (!searchInput || !resultCount || !emptyState) {
        return;
      }

      const url = new URL(window.location.href);
      let activeCategory = url.searchParams.get("category") || "all";

      if (!validCategories.has(activeCategory)) {
        activeCategory = "all";
      }

      searchInput.value = url.searchParams.get("q") || "";

      function getCountLabel(count) {
        if (count === 0) {
          return "No owner-confirmed places found";
        }

        if (count === 1) {
          return "1 owner-confirmed place";
        }

        return `${count} owner-confirmed places`;
      }

      function updateUrl() {
        const nextUrl = new URL(window.location.href);
        const query = searchInput.value.trim();

        if (activeCategory === "all") {
          nextUrl.searchParams.delete("category");
        } else {
          nextUrl.searchParams.set("category", activeCategory);
        }

        if (query) {
          nextUrl.searchParams.set("q", query);
        } else {
          nextUrl.searchParams.delete("q");
        }

        window.history.replaceState({}, "", `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
      }

      function renderDirectory({ syncUrl = true } = {}) {
        const query = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        filterButtons.forEach((button) => {
          const isActive = button.dataset.directoryFilter === activeCategory;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        listingItems.forEach((item) => {
          const groups = (item.dataset.categoryGroups || "").split(/\s+/).filter(Boolean);
          const searchText = item.dataset.searchText || "";
          const categoryMatches = activeCategory === "all" || groups.includes(activeCategory);
          const searchMatches = query === "" || searchText.includes(query);
          const isVisible = categoryMatches && searchMatches;

          item.hidden = !isVisible;

          if (isVisible) {
            visibleCount += 1;
          }
        });

        resultCount.textContent = getCountLabel(visibleCount);
        emptyState.hidden = visibleCount !== 0;

        if (syncUrl) {
          updateUrl();
        }
      }

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeCategory = button.dataset.directoryFilter || "all";
          renderDirectory();
        });
      });

      searchInput.addEventListener("input", () => {
        renderDirectory();
      });

      renderDirectory({ syncUrl: false });
    })();
  </script>
</BaseLayout>
