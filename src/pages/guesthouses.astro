---
import CategoryPageNav from "../components/CategoryPageNav.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Guesthouses in Sen Monorom | Sen Monorom Local Guide"
  description="Guesthouse listings in Sen Monorom are being verified before publication."
>
  <section>
    <div class="container">
      <div class="content-panel page-header">
        <h1>Guesthouses</h1>
        <p class="page-count">0 verified listings</p>
        <p>
          This section will grow slowly as owner-confirmed details are collected and checked for
          accuracy.
        </p>
      </div>

      <CategoryPageNav activeCategory="guesthouse" />

      <div class="empty-state">
        <h2>No verified guesthouses yet</h2>
        <p>
          Guesthouse details are being checked before publication so visitors do not rely on outdated
          booking or contact information.
        </p>
        <p>
          Know a reliable guesthouse in Sen Monorom? Submit it and we will verify the details.
        </p>
        <div class="button-row">
          <a class="button-secondary" href="/#verified-listings">Browse all verified listings</a>
          <a class="button" href="/submit-business">Suggest a guesthouse</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
