---
import CategoryPageNav from "../components/CategoryPageNav.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Motorbike Rentals in Sen Monorom | Sen Monorom Local Guide"
  description="Motorbike rental listings in Sen Monorom are being verified before publication."
>
  <section>
    <div class="container">
      <div class="content-panel page-header">
        <h1>Motorbike Rentals</h1>
        <p class="page-count">0 verified listings</p>
        <p>
          Rental information needs to be practical and current, so listings are being verified before
          they are published.
        </p>
      </div>

      <CategoryPageNav activeCategory="motorbike-rental" />

      <div class="empty-state">
        <h2>No verified motorbike rentals yet</h2>
        <p>
          Rental details are being checked before publication because availability, phone numbers, and
          terms can change quickly.
        </p>
        <p>
          Know a reliable rental provider in Sen Monorom? Submit it and we will verify the details.
        </p>
        <div class="button-row">
          <a class="button-secondary" href="/#verified-listings">Browse all verified listings</a>
          <a class="button" href="/submit-business">Suggest a rental</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
